# Starter values for grafana/loki.
# Review chart documentation for your exact chart version before installation.

loki:
  auth_enabled: false

  commonConfig:
    replication_factor: {{ .Loki.Replicas }}

  storage:
    type: s3
    bucketNames:
      chunks: loki-chunks
      ruler: loki-ruler
      admin: loki-admin
    s3:
      endpoint: {{ .Storage.Endpoint | printf "%q" }}
      region: {{ .Storage.Region | printf "%q" }}
      s3ForcePathStyle: {{ if eq .Storage.Type "minio" }}true{{ else }}false{{ end }}
      insecure: {{ .Storage.Insecure }}
      # Do not place real credentials here.
      # Create a Kubernetes secret manually and wire it according to your chart version.
      # Placeholder style:
      # accessKeyId:
      #   existingSecret: {{ .Storage.AccessKeySecretName }}
      #   existingSecretKey: access_key
      # secretAccessKey:
      #   existingSecret: {{ .Storage.SecretKeySecretName }}
      #   existingSecretKey: secret_key

  schemaConfig:
    configs:
      - from: "2024-01-01"
        store: tsdb
        object_store: s3
        schema: v13
        index:
          prefix: loki_index_
          period: 24h

  limits_config:
    retention_period: {{ .Loki.Retention | printf "%q" }}

  compactor:
    retention_enabled: true
    delete_request_store: s3

backend:
  replicas: {{ .Loki.Replicas }}
read:
  replicas: {{ .Loki.Replicas }}
write:
  replicas: {{ .Loki.Replicas }}

# MinIO mode uses the generated endpoint and path-style S3 access.
# S3-compatible mode should be adjusted for your provider endpoint, TLS, region, and IAM model.
